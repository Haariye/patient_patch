 "font_size": 0,
 "html": "<style>\r\n    .print-format {\r\n        font-family: Arial, sans-serif;\r\n        font-size: 10pt;\r\n        color: #222;\r\n        line-height: 1.4;\r\n        padding: 0 10px;\r\n    }\r\n    .header { margin-bottom: 0; }\r\n\r\n    /* \u2500\u2500 Top row: To + QR \u2500\u2500 */\r\n    .top-row {\r\n        display: table;\r\n        width: 100%;\r\n        margin-bottom: -1px;\r\n        font-weight: 700;\r\n    }\r\n    .top-left {\r\n        display: table-cell;\r\n        vertical-align: middle;\r\n        font-size: 12pt;\r\n    }\r\n    .top-left strong {\r\n        display: inline-block;\r\n        width: 30px;\r\n    }\r\n    .top-right {\r\n        display: table-cell;\r\n        vertical-align: middle;\r\n        text-align: right;\r\n        width: 80px;\r\n    }\r\n    .top-right img {\r\n        width: 72px;\r\n        height: 72px;\r\n         margin-bottom: -10px;\r\n         margin-top: 10px;\r\n         margin-right: 20px;\r\n    }\r\n    }\r\n\r\n    .subject-line {\r\n        font-size: 13pt;\r\n        \r\n    }\r\n    .subject-line strong {\r\n        display: inline-block;\r\n        width: 80px;\r\n        font-size: 13pt;\r\n    }\r\n    .subject-value {\r\n        font-weight: 700;\r\n        font-size: 13pt;\r\n    }\r\n\r\n    /* \u2500\u2500 Ref block: top + bottom border only \u2500\u2500 */\r\n    .ref-block {\r\n        border-top: 1.5px solid #333;\r\n        border-bottom: 1.5px solid #333;\r\n        padding: 4px 0;\r\n        margin-bottom: 4px;\r\n    }\r\n    .info-line {\r\n        display: table;\r\n        width: 100%;\r\n    }\r\n    .info-line .cell {\r\n        display: table-cell;\r\n        padding: 1px 4px;\r\n        font-size: 9.5pt;\r\n        vertical-align: top;\r\n    }\r\n    .info-line .lbl {\r\n        font-weight: 700;\r\n        color: #333;\r\n        width: 14%;\r\n        white-space: nowrap;\r\n    }\r\n    .info-line .val {\r\n        width: 36%;\r\n        color: #111;\r\n    }\r\n\r\n    /* \u2500\u2500 Patient details: no borders \u2500\u2500 */\r\n    .patient-block {\r\n        padding: 3px 0 4px 0;\r\n    }\r\n\r\n    /* \u2500\u2500 Thin separator \u2500\u2500 */\r\n    .sep {\r\n        border: none;\r\n        border-top: 1px solid #ccc;\r\n        margin: 6px 0;\r\n    }\r\n\r\n    /* \u2500\u2500 Section headings \u2500\u2500 */\r\n    .sec-heading {\r\n        font-weight: 900;\r\n        font-size: 12pt;\r\n        color: #1a6b5a;\r\n        margin: 10px 0 2px 0;\r\n    }\r\n    .sec-content {\r\n        font-size: 10pt;\r\n        white-space: pre-wrap;\r\n        margin: 0 0 2px 0;\r\n        min-height: 10px;\r\n        line-height: 1.5;\r\n        color: #222;\r\n    }\r\n\r\n    /* \u2500\u2500 Vital signs row \u2500\u2500 */\r\n    .vitals-strip {\r\n        display: table;\r\n        width: 100%;\r\n        margin-bottom: 2px;\r\n    }\r\n    .vitals-strip .v-item {\r\n        display: table-cell;\r\n        font-size: 9pt;\r\n        padding: 2px 6px;\r\n        color: #444;\r\n    }\r\n    .vitals-strip .v-item strong {\r\n        color: #333;\r\n    }\r\n\r\n    /* \u2500\u2500 Signature \u2500\u2500 */\r\n    .sign-off {\r\n        text-align: center;\r\n        margin-top: 34px;\r\n    }\r\n    .sign-off .regards {\r\n        font-style: italic;\r\n        font-size: 10pt;\r\n        margin-bottom: 2px;\r\n    }\r\n    .sign-off .doc-name {\r\n        font-weight: 700;\r\n        font-size: 10.5pt;\r\n    }\r\n    .sign-off .doc-dept {\r\n        font-size: 9pt;\r\n        color: #555;\r\n        margin-top: 1px;\r\n    }\r\n    .sign-line {\r\n        width: 160px;\r\n        border-top: 1px solid #333;\r\n        margin: 30px auto 0 auto;\r\n    }\r\n\r\n    /* \u2500\u2500 Footer \u2500\u2500 */\r\n    .report-footer {\r\n        margin-top: 18px;\r\n        border-top: 1.5px solid #1a6b5a;\r\n        padding-top: 6px;\r\n        text-align: center;\r\n        font-size: 8pt;\r\n        color: #444;\r\n        line-height: 1.5;\r\n    }\r\n    .report-footer .fc-name {\r\n        font-weight: 700;\r\n        font-size: 9.5pt;\r\n        text-transform: uppercase;\r\n        letter-spacing: 0.5px;\r\n        color: #111;\r\n    }\r\n    .confidential-line {\r\n        margin-top: 6px;\r\n        font-size: 7pt;\r\n        color: #888;\r\n        font-style: italic;\r\n    }\r\n\r\n    @media print {\r\n        .print-format { padding: 0; }\r\n    }\r\n</style>\r\n\r\n<div class=\"print-format\">\r\n\r\n    {% if letter_head %}\r\n    <div class=\"header\">{{ letter_head }}</div>\r\n    {% endif %}\r\n\r\n <div class=\"top-row\">\r\n    <div class=\"top-left\">\r\n        <strong>To:</strong> Whom It May Concern\r\n    </div>\r\n    <div class=\"top-right\">\r\n        {% set qr_value = frappe.utils.get_url_to_form(doc.doctype, doc.name) %}\r\n        <img\r\n            src=\"https://api.qrserver.com/v1/create-qr-code/?size=150x150&data={{ qr_value }}\"\r\n            alt=\"QR Code\"\r\n            style=\"width:70px; height:70px;\"\r\n        >\r\n    </div>\r\n</div>\r\n\r\n    <div class=\"subject-line\">\r\n        <strong>Subject:</strong> <span class=\"subject-value\">Medical Report</span>\r\n    </div>\r\n\r\n    <!-- \u2500\u2500 Ref block: top + bottom lines only \u2500\u2500 -->\r\n    <div class=\"ref-block\">\r\n        <div class=\"info-line\">\r\n            <div class=\"cell lbl\">Ref No:</div>\r\n            <div class=\"cell val\">{{ doc.name }}</div>\r\n            <div class=\"cell lbl\">Date:</div>\r\n            <div class=\"cell val\">{{ frappe.utils.formatdate(doc.report_date) }}</div>\r\n        </div>\r\n        <div class=\"info-line\">\r\n            <div class=\"cell lbl\">Report Date:</div>\r\n            <div class=\"cell val\">{{ frappe.utils.formatdate(doc.report_date) }}</div>\r\n            <div class=\"cell lbl\">Patient ID:</div>\r\n            <div class=\"cell val\">{{ doc.get('patient_id') or doc.get('patient') or '' }}</div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- \u2500\u2500 Patient details: no lines \u2500\u2500 -->\r\n    <div class=\"patient-block\">\r\n        <div class=\"info-line\">\r\n            <div class=\"cell lbl\">Name:</div>\r\n            <div class=\"cell val\">{{ doc.get('patient_name') or '' }}</div>\r\n            <div class=\"cell lbl\">Sex:</div>\r\n            <div class=\"cell val\">{{ doc.get('sex') or '' }}</div>\r\n        </div>\r\n        <div class=\"info-line\">\r\n            <div class=\"cell lbl\">Age:</div>\r\n            <div class=\"cell val\">{{ doc.get('age') or '' }}</div>\r\n            <div class=\"cell lbl\">Doctor:</div>\r\n            <div class=\"cell val\">{{ doc.get('doctor') or '' }}</div>\r\n        </div>\r\n        {% if doc.get('medical_department') %}\r\n        <div class=\"info-line\">\r\n            <div class=\"cell lbl\">Department:</div>\r\n            <div class=\"cell val\">{{ doc.medical_department }}</div>\r\n            <div class=\"cell lbl\"></div>\r\n            <div class=\"cell val\"></div>\r\n        </div>\r\n        {% endif %}\r\n        <div class=\"info-line\">\r\n            <div class=\"cell lbl\">Date In:</div>\r\n            <div class=\"cell val\">{{ frappe.utils.formatdate(doc.get('admission_date') or doc.report_date) }}</div>\r\n            <div class=\"cell lbl\">Date Out:</div>\r\n            <div class=\"cell val\">{{ frappe.utils.formatdate(doc.get('discharge_date') or doc.report_date) }}</div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- \u2500\u2500 Vitals strip (only if any vital exists) \u2500\u2500 -->\r\n    {% if doc.get('bp') or doc.get('pulse') or doc.get('temperature') or doc.get('weight') or doc.get('height') %}\r\n    <hr class=\"sep\">\r\n    <div class=\"vitals-strip\">\r\n        {% if doc.get('bp') %}<div class=\"v-item\"><strong>BP:</strong> {{ doc.bp }}</div>{% endif %}\r\n        {% if doc.get('pulse') %}<div class=\"v-item\"><strong>Pulse:</strong> {{ doc.pulse }}</div>{% endif %}\r\n        {% if doc.get('temperature') %}<div class=\"v-item\"><strong>Temp:</strong> {{ doc.temperature }}</div>{% endif %}\r\n        {% if doc.get('weight') %}<div class=\"v-item\"><strong>Weight:</strong> {{ doc.weight }} kg</div>{% endif %}\r\n        {% if doc.get('height') %}<div class=\"v-item\"><strong>Height:</strong> {{ doc.height }} cm</div>{% endif %}\r\n    </div>\r\n    {% endif %}\r\n\r\n    <!-- \u2500\u2500 Chief Complaint (if exists) \u2500\u2500 -->\r\n    {% if doc.get('chief_complaint') %}\r\n    <hr class=\"sep\">\r\n    <div class=\"sec-heading\">Chief Complaint:</div>\r\n    <div class=\"sec-content\">{{ doc.chief_complaint }}</div>\r\n    {% endif %}\r\n\r\n    <!-- \u2500\u2500 Allergies (if exists) \u2500\u2500 -->\r\n    {% if doc.get('allergies') %}\r\n    <div class=\"sec-heading\">Known Allergies:</div>\r\n    <div class=\"sec-content\">{{ doc.allergies }}</div>\r\n    {% endif %}\r\n\r\n    <hr class=\"sep\">\r\n\r\n    <!-- \u2500\u2500 Core Sections \u2500\u2500 -->\r\n    <div class=\"sec-heading\">Diagnosis:</div>\r\n    <div class=\"sec-content\">{{ doc.get('diagnosis') or '' }}</div>\r\n\r\n    <div class=\"sec-heading\">Treatment:</div>\r\n    <div class=\"sec-content\">{{ doc.get('treatment') or '' }}</div>\r\n\r\n    <div class=\"sec-heading\">Recommendation:</div>\r\n    <div class=\"sec-content\">{{ doc.get('recommendation') or '' }}</div>\r\n\r\n    <!-- \u2500\u2500 Follow-up (if exists) \u2500\u2500 -->\r\n    {% if doc.get('follow_up_date') %}\r\n    <div class=\"sec-heading\">Follow-up Date:</div>\r\n    <div class=\"sec-content\">{{ frappe.utils.formatdate(doc.follow_up_date) }}</div>\r\n    {% endif %}\r\n\r\n    <!-- \u2500\u2500 Signature \u2500\u2500 -->\r\n    <div class=\"sign-off\">\r\n        <div class=\"regards\">Best Regards</div>\r\n        <div class=\"doc-name\">{{ doc.get('doctor') or '' }}</div>\r\n        {% if doc.get('medical_department') %}\r\n        <div class=\"doc-dept\">{{ doc.medical_department }}</div>\r\n        {% endif %}\r\n        <div class=\"sign-line\"></div>\r\n    </div>\r\n\r\n    <!-- \u2500\u2500 Footer \u2500\u2500 -->\r\n    <div class=\"report-footer\">\r\n        <div class=\"fc-name\">HIRAAL CLINIC</div>\r\n        Address: Xero Awr - Kaa soo horjeedka Majid nuur, Sh. Ismael Dheeg - Hargeisa, Somaliland<br>\r\n        Tel: +252 63 8600888 / +252 65 8600888<br>\r\n        Email: info@hiraalclinic.com<br>\r\n        Website: www.hiraalclinic.com\r\n        <div class=\"confidential-line\">This document is confidential and intended solely for the named patient and their authorized healthcare providers.</div>\r\n    </div>\r\n\r\n</div>",
